{
    "compilerOptions": {
        "rootDir": "./",
        "baseUrl": "./",
        "paths": {
            "@/*": ["./apps/*"]
        },
        "outDir": "./dist",
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "module": "ESNext",
        "moduleResolution": "Node",
        "target": "ESNext",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true
    },
    "include": ["."],
    "exclude": ["node_modules", "build"]
}
